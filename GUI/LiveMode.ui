   <string notr="true">/* Main Background */
QWidget {
    background-color: #1A1A1D;
    color: #E3E3E3;
    font-family: "Quicksand", "Segoe UI", sans-serif;
    font-size: 18px;
}

/* Elegant Tables */
QTableWidget {
    background-color: #252529;
    gridline-color: #3B3B3F;
    border: 1px solid #4E4E52;
    border-radius: 10px;
    selection-background-color: #F48FB1;
    selection-color: #1A1A1D;
}

QHeaderView::section {
    background-color: #2D2D32;
    color: #F48FB1;
    padding: 8px;
    border: none;
    font-weight: bold;
    text-transform: uppercase;
}

/* Light Pink Professional Buttons */
QPushButton {
    background-color: #F8BBD0;
    color: #36454F;
    border-radius: 8px;
    padding: 10px;
    font-weight: 700;
    letter-spacing: 1px;
}

QPushButton:hover {
    background-color: #FCE4EC;
    border: 1px solid #F48FB1;
}

/* Input Fields */
QLineEdit, QComboBox {
    border: 2px solid #3B3B3F;
    border-radius: 6px;
    padding: 5px;
    background: #121214;
    color: #F8BBD0;
}
</string>
